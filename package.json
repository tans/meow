{
  "name": "meow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run apps/entry/server.js",
    "entry": "bun run apps/entry/server.js",
    "api": "bun run apps/api/server.js",
    "test:api": "bun test apps/api/tests --timeout 20000",
    "test:entry": "bun test apps/entry/server.test.js apps/entry/tests/server.test.js --timeout 20000",
    "test": "bun run test:api && bun run test:entry"
  }
}
