# API service runtime environment

# HTTP listen port
PORT=3001

# SQLite database file path
MEOW_DB_PATH=meow.sqlite

# Demo auth switches
# Prefer enabling one of the two flags below in demo environments only.
MEOW_DEMO_AUTH=false
# MEOW_AUTH_MODE=demo

# Seed demo data on boot (demo/first-run only)
MEOW_DEMO_SEED=false

# Mark session cookies as Secure in HTTPS environments
MEOW_COOKIE_SECURE=false

# Uploaded asset storage directory
MEOW_UPLOAD_DIR=apps/api/uploads
