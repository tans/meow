page {
  min-height: 100%;
  background: #f1f6fb;
  color: #16304a;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
}

.card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(46, 79, 122, 0.1);
}

.page-section {
  display: grid;
  gap: 20rpx;
  margin-top: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #16304a;
}

.page-subtitle {
  margin-top: 12rpx;
  color: #5c7089;
  font-size: 26rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #2b7de9;
  font-size: 22rpx;
  font-weight: 600;
}

.list-card {
  display: grid;
  gap: 16rpx;
}

.list-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(46, 79, 122, 0.08);
}

.list-card__title {
  font-size: 30rpx;
  font-weight: 600;
}

.list-card__meta {
  margin-top: 8rpx;
  color: #6a7b91;
  font-size: 24rpx;
}

.native-form {
  display: grid;
  gap: 18rpx;
}

.native-form__field {
  display: grid;
  gap: 10rpx;
}

.native-form__label {
  color: #4f6179;
  font-size: 24rpx;
}

.native-form__input {
  min-height: 84rpx;
  padding: 0 24rpx;
  border: 2rpx solid #dbe6f3;
  border-radius: 24rpx;
  background: #ffffff;
  font-size: 28rpx;
}

.native-button {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #4f8ef7, #2b7de9);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.native-button--ghost {
  background: #edf4ff;
  color: #2b7de9;
}

.native-empty {
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #6a7b91;
  text-align: center;
}
